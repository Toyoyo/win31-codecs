# mp3acm16.lnk - wlink response file for 16-bit mp3 ACM driver
system windows dll initinstance
name mp3acm16.acm
file mp3acm.obj
option map=mp3acm16.map
option quiet
option modname=mp3acm16
option description 'MPEG-1 Layer 2 Audio ACM Codec for Windows 3.1'
option heapsize=4096
library windows.lib
library mmsystem.lib
library clibl.lib
# WEP must be RESIDENTNAME for Windows 3.x
export WEP.1 RESIDENT
#export DriverProc.2
