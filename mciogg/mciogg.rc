#include <windows.h>

100 DIALOG 30, 20, 240, 92
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "OGG Vorbis Audio Driver"
BEGIN
    CTEXT "OGG Vorbis Audio MCI Driver", -1, 8, 10, 224, 10
    CTEXT "Plays OGG Vorbis files in Windows Media Player.", -1, 8, 24, 224, 16
    CTEXT "Uses stb_vorbis decoder. Requires a 387-compatible FPU.", -1, 8, 42, 224, 10
    CTEXT "", 101, 8, 58, 224, 10
    DEFPUSHBUTTON "OK", IDOK, 96, 74, 48, 14
END
